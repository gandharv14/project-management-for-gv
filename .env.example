# App
# Leave APP_BASE_URL unset so Auth0 can infer the current request host.
# Set it only if every login starts and returns on one stable origin.
# APP_BASE_URL=http://localhost:3000
MANAGER_EMAIL=you@labelbox.com
CRON_SECRET=replace-with-a-random-secret
SUGGESTION_TRACTION_THRESHOLD=3

# Auth0
# Configure the Auth0 app to allow only the Labelbox SSO connection, or set
# AUTH0_CONNECTION to the exact enabled connection name for this Auth0 application.
# Leave AUTH0_CONNECTION empty if the connection is not enabled for the app yet.
# Local Auth0 URLs:
# - Allowed Callback URLs: http://localhost:3000/auth/callback
# - Allowed Logout URLs: http://localhost:3000
# - Allowed Web Origins: http://localhost:3000
# Vercel Auth0 URLs:
# - Allowed Callback URLs: https://<your-vercel-domain>/auth/callback
# - Allowed Logout URLs: https://<your-vercel-domain>
# - Allowed Web Origins: https://<your-vercel-domain>
AUTH0_SECRET=replace-with-32-byte-random-secret
AUTH0_DOMAIN=your-tenant.us.auth0.com
AUTH0_CLIENT_ID=replace-with-auth0-client-id
AUTH0_CLIENT_SECRET=replace-with-auth0-client-secret
AUTH0_CONNECTION=

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-with-service-role-key
# The anon key is no longer used by the app (all access is server-side via the
# service role, and Row Level Security denies anon). It is only needed to run
# the e2e security test that asserts the anon key is denied direct table access.
# NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-with-anon-key
